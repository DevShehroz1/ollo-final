{%- liquid
  assign sec_st = section.settings
  if sec_st.reset_spacing
    assign reset_spacing = ' remove_spacing'
  endif
  assign pt_mobile = sec_st.padding_top_mobile
  if pt_mobile == 0
    assign pt_mobile = sec_st.padding_top
  endif
  assign pb_mobile = sec_st.padding_bottom_mobile
  if pb_mobile == 0
    assign pb_mobile = sec_st.padding_bottom
  endif

  assign side_class = ''
  if sec_st.image_side == 'left'
    assign side_class = ' story-feature-3--image-left'
  endif

  assign treatment = sec_st.outer_treatment | default: 'grayscale'
  assign darken = sec_st.darken_amount | default: 40
  assign overlay_alpha = darken | times: 0.01

  assign heading_color = sec_st.heading_color | default: sec_st.text_color
  assign divider_color = sec_st.divider_color | default: sec_st.text_color
  assign description_color = sec_st.description_color | default: sec_st.text_color
  assign desc_3_color = sec_st.desc_3_color | default: sec_st.text_color
-%}
<div
  class="story-feature-3{{ reset_spacing }}{{ side_class }}"
  style="background-color: {{ sec_st.bg_color }};"
>
  <div class="story-feature-3__inner">
    <div class="story-feature-3__media">
      <div class="story-feature-3__media-stack">
        <div class="story-feature-3__outer-wrap">
          {%- if sec_st.image != blank -%}
            {%- assign image_alt = sec_st.image.alt | default: 'Story' -%}
            {{
              sec_st.image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                alt: image_alt,
                class: 'story-feature-3__img-outer',
                widths: '720, 1080, 1440, 1600',
                sizes: '(max-width: 767px) 100vw, 50vw'
            }}
          {%- else -%}
            <span class="story-feature-3__img-outer story-feature-3__img-outer--placeholder" aria-hidden="true"></span>
          {%- endif -%}
          {%- if treatment == 'black_overlay' or treatment == 'both' -%}
            <span class="story-feature-3__overlay" aria-hidden="true"></span>
          {%- endif -%}
          {%- if sec_st.image_inner != blank -%}
            {%- assign inner_alt = sec_st.image_inner.alt | default: 'Detail' -%}
            {{
              sec_st.image_inner
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                alt: inner_alt,
                class: 'story-feature-3__img-inner',
                widths: '480, 720, 900',
                sizes: '(max-width: 767px) 60vw, 30vw'
            }}
          {%- endif -%}
        </div>
      </div>
    </div>
    <div class="story-feature-3__text">
      <div class="story-feature-3__top">
        {%- if sec_st.description_1 != blank -%}
          <p class="story-feature-3__desc story-feature-3__desc--1">{{ sec_st.description_1 | newline_to_br }}</p>
        {%- endif -%}
        <hr class="story-feature-3__divider">
        {%- if sec_st.description_2 != blank -%}
          <p class="story-feature-3__desc story-feature-3__desc--2">{{ sec_st.description_2 | newline_to_br }}</p>
        {%- endif -%}
      </div>
      {%- if sec_st.description_3 != blank -%}
        <div class="story-feature-3__bottom">
          <p class="story-feature-3__desc story-feature-3__desc--3">{{ sec_st.description_3 | newline_to_br }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% style %}
  #shopify-section-{{ section.id }} br {
    display: inline;
  }
  #shopify-section-{{ section.id }} .story-feature-3 {
    overflow: hidden;
    padding-top: {{ sec_st.padding_top | default: 0 }}px;
    padding-bottom: {{ sec_st.padding_bottom | default: 0 }}px;
  }
  #shopify-section-{{ section.id }} .story-feature-3__inner {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    max-width: {{ sec_st.section_max_width_desktop | default: 1200 }}px;
    margin: 0 auto;
    padding-left: {{ sec_st.section_side_padding_desktop | default: 24 }}px;
    padding-right: {{ sec_st.section_side_padding_desktop | default: 24 }}px;
    box-sizing: border-box;
  }
  #shopify-section-{{ section.id }} .story-feature-3--image-left .story-feature-3__inner {
    flex-direction: row-reverse;
  }
  #shopify-section-{{ section.id }} .story-feature-3__media {
    flex: 0 0 50%;
    width: 50%;
    padding: 50px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .story-feature-3__media-stack {
    position: relative;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .story-feature-3__outer-wrap {
    position: relative;
    width: {{ sec_st.outer_image_width_desktop | default: 100 }}%;
    margin: 0 auto;
    border-radius: {{ sec_st.outer_image_radius | default: 0 }}px;
    overflow: hidden;
    background-color: #000;
  }
  #shopify-section-{{ section.id }} .story-feature-3__img-outer {
    display: block;
    width: 100%;
    height: auto;
    {%- if treatment == 'grayscale' or treatment == 'both' %}
    filter: grayscale(100%);
    {%- endif %}
  }
  #shopify-section-{{ section.id }} .story-feature-3__img-outer--placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #2a2a2a;
  }
  #shopify-section-{{ section.id }} .story-feature-3__overlay {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: {{ overlay_alpha }};
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .story-feature-3__img-inner {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ sec_st.inner_image_width_desktop | default: 60 }}%;
    height: auto;
    display: block;
    border-radius: {{ sec_st.inner_image_radius | default: 12 }}px;
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.45);
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .story-feature-3__text {
    flex: 0 0 50%;
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 50px 50px 50px 20px;
    box-sizing: border-box;
  }
  #shopify-section-{{ section.id }} .story-feature-3--image-left .story-feature-3__text {
    padding-left: 50px;
    padding-right: 20px;
  }
  #shopify-section-{{ section.id }} .story-feature-3__top {
    display: flex;
    flex-direction: column;
    gap: {{ sec_st.top_gap_desktop | default: 20 }}px;
    transform: translateY({{ sec_st.top_offset_y_desktop | default: 0 }}px);
  }
  #shopify-section-{{ section.id }} .story-feature-3__bottom {
    transform: translateY({{ sec_st.bottom_offset_y_desktop | default: 0 }}px);
  }
  #shopify-section-{{ section.id }} .story-feature-3__desc {
    margin: 0;
    letter-spacing: 0;
  }
  #shopify-section-{{ section.id }} .story-feature-3__desc--1 {
    font-family: 'Inter', sans-serif;
    font-weight: {{ sec_st.desc_1_weight | default: 700 }};
    font-size: {{ sec_st.desc_1_size_desktop | default: 16 }}px;
    line-height: 1.3;
    color: {{ heading_color }};
    {%- if sec_st.desc_1_max_width_desktop and sec_st.desc_1_max_width_desktop > 0 %}
    max-width: {{ sec_st.desc_1_max_width_desktop }}px;
    {%- endif %}
  }
  #shopify-section-{{ section.id }} .story-feature-3__divider {
    width: 80px;
    height: 0;
    border: none;
    border-top: 2px solid {{ divider_color }};
    margin: 0;
    opacity: {%- if sec_st.show_divider %} 1 {%- else %} 0 {%- endif -%};
  }
  #shopify-section-{{ section.id }} .story-feature-3__desc--2 {
    font-family: 'Inter', sans-serif;
    font-weight: {{ sec_st.desc_2_weight | default: 400 }};
    font-size: {{ sec_st.desc_2_size_desktop | default: 18 }}px;
    line-height: 1.4;
    color: {{ description_color }};
    {%- if sec_st.desc_2_max_width_desktop and sec_st.desc_2_max_width_desktop > 0 %}
    max-width: {{ sec_st.desc_2_max_width_desktop }}px;
    {%- endif %}
  }
  #shopify-section-{{ section.id }} .story-feature-3__desc--3 {
    font-family: 'Inter', sans-serif;
    font-weight: {{ sec_st.desc_3_weight | default: 700 }};
    font-size: {{ sec_st.desc_3_size_desktop | default: 16 }}px;
    line-height: 1.3;
    color: {{ desc_3_color }};
    {%- if sec_st.desc_3_max_width_desktop and sec_st.desc_3_max_width_desktop > 0 %}
    max-width: {{ sec_st.desc_3_max_width_desktop }}px;
    {%- endif %}
  }
  @media screen and (max-width: 1199px) {
    #shopify-section-{{ section.id }} .story-feature-3__media {
      padding: 30px;
    }
    #shopify-section-{{ section.id }} .story-feature-3__text {
      padding-left: 20px;
      padding-right: 30px;
    }
    #shopify-section-{{ section.id }} .story-feature-3--image-left .story-feature-3__text {
      padding-left: 30px;
      padding-right: 20px;
    }
  }
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .story-feature-3 {
      padding-top: {{ pt_mobile | default: 0 }}px;
      padding-bottom: {{ pb_mobile | default: 0 }}px;
    }
    #shopify-section-{{ section.id }} .story-feature-3__inner,
    #shopify-section-{{ section.id }} .story-feature-3--image-left .story-feature-3__inner {
      flex-direction: column;
      align-items: stretch;
      max-width: {{ sec_st.section_max_width_mobile | default: 100 }}%;
      padding-left: {{ sec_st.section_side_padding_mobile | default: 0 }}px;
      padding-right: {{ sec_st.section_side_padding_mobile | default: 0 }}px;
    }
    #shopify-section-{{ section.id }} .story-feature-3__media {
      flex: none;
      width: 100%;
      padding: 20px 20px 0;
    }
    #shopify-section-{{ section.id }} .story-feature-3__outer-wrap {
      width: {{ sec_st.outer_image_width_mobile | default: 100 }}%;
    }
    #shopify-section-{{ section.id }} .story-feature-3__img-inner {
      width: {{ sec_st.inner_image_width_mobile | default: 70 }}%;
    }
    #shopify-section-{{ section.id }} .story-feature-3__text,
    #shopify-section-{{ section.id }} .story-feature-3--image-left .story-feature-3__text {
      flex: none;
      width: 100%;
      padding: 50px 20px;
    }
    #shopify-section-{{ section.id }} .story-feature-3__top {
      gap: {{ sec_st.top_gap_mobile | default: 16 }}px;
      transform: translateY({{ sec_st.top_offset_y_mobile | default: 0 }}px);
    }
    #shopify-section-{{ section.id }} .story-feature-3__bottom {
      transform: translateY({{ sec_st.bottom_offset_y_mobile | default: 0 }}px);
      margin-top: {{ sec_st.bottom_gap_mobile | default: 32 }}px;
    }
    #shopify-section-{{ section.id }} .story-feature-3__desc--1 {
      font-size: {{ sec_st.desc_1_size_mobile | default: 16 }}px;
      {%- if sec_st.desc_1_max_width_mobile and sec_st.desc_1_max_width_mobile > 0 %}
      max-width: {{ sec_st.desc_1_max_width_mobile }}px;
      {%- endif %}
    }
    #shopify-section-{{ section.id }} .story-feature-3__desc--2 {
      font-size: {{ sec_st.desc_2_size_mobile | default: 16 }}px;
      {%- if sec_st.desc_2_max_width_mobile and sec_st.desc_2_max_width_mobile > 0 %}
      max-width: {{ sec_st.desc_2_max_width_mobile }}px;
      {%- endif %}
    }
    #shopify-section-{{ section.id }} .story-feature-3__desc--3 {
      font-size: {{ sec_st.desc_3_size_mobile | default: 16 }}px;
      {%- if sec_st.desc_3_max_width_mobile and sec_st.desc_3_max_width_mobile > 0 %}
      max-width: {{ sec_st.desc_3_max_width_mobile }}px;
      {%- endif %}
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Story Feature 3",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#363B48"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Default text color (fallback)",
      "default": "#FFF8B8"
    },
    {
      "type": "header",
      "content": "Top text — heading paragraph"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Heading paragraph",
      "default": "Built for skin that moves."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "select",
      "id": "desc_1_weight",
      "label": "Heading weight",
      "default": "700",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ]
    },
    {
      "type": "range",
      "id": "desc_1_size_desktop",
      "label": "Heading size — Desktop",
      "default": 16,
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_1_size_mobile",
      "label": "Heading size — Mobile",
      "default": 16,
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Top text — divider + paragraph"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider line",
      "default": true
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color"
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Description paragraph",
      "default": "We wanted body care that holds up between meetings, workouts, and the moments in between — not the kind that fades the second you sweat."
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color"
    },
    {
      "type": "select",
      "id": "desc_2_weight",
      "label": "Description weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "desc_2_size_desktop",
      "label": "Description size — Desktop",
      "default": 18,
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_2_size_mobile",
      "label": "Description size — Mobile",
      "default": 16,
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Bottom text — bold tagline"
    },
    {
      "type": "textarea",
      "id": "description_3",
      "label": "Bottom text",
      "default": "Built for the way you actually live."
    },
    {
      "type": "color",
      "id": "desc_3_color",
      "label": "Bottom text color"
    },
    {
      "type": "select",
      "id": "desc_3_weight",
      "label": "Bottom text weight",
      "default": "700",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ]
    },
    {
      "type": "range",
      "id": "desc_3_size_desktop",
      "label": "Bottom text size — Desktop",
      "default": 16,
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_3_size_mobile",
      "label": "Bottom text size — Mobile",
      "default": 16,
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Vertical positioning"
    },
    {
      "type": "paragraph",
      "content": "Negative pulls up, positive pushes down. Use these to fine-tune where the top group and bottom text sit inside the column."
    },
    {
      "type": "range",
      "id": "top_offset_y_desktop",
      "label": "Top group vertical offset — Desktop",
      "default": 0,
      "min": -200,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "top_offset_y_mobile",
      "label": "Top group vertical offset — Mobile",
      "default": 0,
      "min": -120,
      "max": 120,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bottom_offset_y_desktop",
      "label": "Bottom text vertical offset — Desktop",
      "default": 0,
      "min": -200,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bottom_offset_y_mobile",
      "label": "Bottom text vertical offset — Mobile",
      "default": 0,
      "min": -120,
      "max": 120,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "top_gap_desktop",
      "label": "Gap inside top group — Desktop",
      "default": 20,
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "top_gap_mobile",
      "label": "Gap inside top group — Mobile",
      "default": 16,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bottom_gap_mobile",
      "label": "Gap above bottom text — Mobile",
      "info": "Mobile only. Adds breathing room above the bottom text when the layout stacks vertically.",
      "default": 32,
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Text width"
    },
    {
      "type": "paragraph",
      "content": "0 = no override (current line widths). Increase to constrain the paragraph width."
    },
    {
      "type": "range",
      "id": "desc_1_max_width_desktop",
      "label": "Heading max width — Desktop",
      "default": 0,
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_1_max_width_mobile",
      "label": "Heading max width — Mobile",
      "default": 0,
      "min": 0,
      "max": 800,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_2_max_width_desktop",
      "label": "Description max width — Desktop",
      "default": 0,
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_2_max_width_mobile",
      "label": "Description max width — Mobile",
      "default": 0,
      "min": 0,
      "max": 800,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_3_max_width_desktop",
      "label": "Bottom text max width — Desktop",
      "default": 0,
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_3_max_width_mobile",
      "label": "Bottom text max width — Mobile",
      "default": 0,
      "min": 0,
      "max": 800,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_side",
      "label": "Image side (desktop)",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "section_max_width_desktop",
      "label": "Section max width — Desktop",
      "info": "Maximum width of the image+text row. Lower this to make the section narrower.",
      "default": 1200,
      "min": 600,
      "max": 1800,
      "step": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_side_padding_desktop",
      "label": "Section side padding — Desktop",
      "default": 24,
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_max_width_mobile",
      "label": "Section max width — Mobile",
      "info": "Percentage of the viewport width. 100% = full-width on mobile.",
      "default": 100,
      "min": 60,
      "max": 100,
      "step": 2,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "section_side_padding_mobile",
      "label": "Section side padding — Mobile",
      "default": 0,
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Outer image"
    },
    {
      "type": "paragraph",
      "content": "Outer image is rendered at its natural aspect ratio. Use the width sliders to scale it up or down."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Outer image"
    },
    {
      "type": "range",
      "id": "outer_image_width_desktop",
      "label": "Outer image width (desktop)",
      "info": "% of the media column. 100% fills the column, lower values shrink the image while keeping its natural aspect.",
      "min": 50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "outer_image_width_mobile",
      "label": "Outer image width (mobile)",
      "min": 50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "outer_treatment",
      "label": "Outer image treatment",
      "options": [
        { "value": "grayscale", "label": "Grayscale" },
        { "value": "black_overlay", "label": "Black overlay" },
        { "value": "both", "label": "Grayscale + black overlay" },
