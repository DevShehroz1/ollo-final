<style>
  .refill-product-section {
    padding: 40px 0;
  }
  .refill-product__grid {
    display: grid;
    grid-template-columns: {{ section.settings.media_col_fr | default: 115 | divided_by: 100.0 }}fr {{ section.settings.info_col_fr | default: 100 | divided_by: 100.0 }}fr;
    gap: {{ section.settings.grid_gap | default: 32 }}px;
    align-items: stretch;
  }

  /* ---- MEDIA LEFT ---- */
  /* Thumbnails on the left, main image on the right inside the media column. */
  .refill-product__media-col {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 12px;
    align-items: start;
  }
  .refill-product__main-image {
    border-radius: {{ section.settings.main_image_radius | default: 15 }}px;
    overflow: hidden;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.main_image_size_pct | default: 100 }}%;
    {%- if section.settings.main_image_height_px and section.settings.main_image_height_px > 0 -%}
    height: {{ section.settings.main_image_height_px }}px;
    {%- else -%}
    height: 100%;
    align-self: stretch;
    {%- endif -%}
    min-height: 0;
    margin-left: 0;
    margin-right: auto;
    position: relative;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }
  .refill-product__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.85);
    color: #1a1a1a;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.12);
    -webkit-appearance: none;
    appearance: none;
    -webkit-tap-highlight-color: transparent;
    padding: 0;
  }
  .refill-product__arrow:hover { background: #ffffff; }
  .refill-product__arrow:active { transform: translateY(-50%) scale(0.95); }
  .refill-product__arrow svg { width: 18px; height: 18px; display: block; }
  .refill-product__arrow--prev { left: 12px; }
  .refill-product__arrow--next { right: 12px; }
  .refill-product__dots {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: none;
    gap: 8px;
    z-index: 2;
    padding: 6px 10px;
    border-radius: 999px;
  }
  .refill-product__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.18);
    transition: background 0.2s, transform 0.2s;
  }
  .refill-product__dot.active {
    background: #BFCED6;
    transform: scale(1.15);
  }

  .refill-product__main-image img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .refill-product__thumbnails {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.thumbnail_gap_px | default: 8 }}px;
  }

  .refill-product__thumbnail {
    width: 80px;
    height: {{ section.settings.thumbnail_height_px | default: 80 }}px;
    border-radius: 4px;
    overflow: hidden;
    background: #f0f0f0;
    cursor: pointer;
    border: 2px solid transparent;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }

  .refill-product__thumbnail.active,
  .refill-product__thumbnail:hover {
    border-color: #000;
  }

  .refill-product__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---- INFO RIGHT ---- */
  .refill-product__info {
    text-align: left;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .refill-product__title-price-row {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    margin-bottom: 16px;
  }

  /* Small uppercase eyebrow above the title (e.g. "REFILLABLE DEODORANT POD") */
  .refill-product__eyebrow {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 13px;
    line-height: 1.3;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
    color: #000;
  }

  /* Title + side badge row */
  .refill-product__title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin: 0;
  }
  .refill-product__title {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 30px;
    line-height: 36px;
    letter-spacing: 0;
    text-transform: uppercase;
    text-align: left;
    margin: 0;
    color: #000;
    flex: 1 1 auto;
    min-width: 0;
  }
  .refill-product__title-badge {
    flex: 0 0 auto;
    align-self: flex-start;
    background: #BFCED6;
    color: #000;
    padding: 6px 14px;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Short description (rendered from product metafield custom.short) */
  .refill-product__short {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 22px;
    letter-spacing: 0;
    text-align: left;
    margin: 6px 0 22px;
    color: #1a1a1a;
    white-space: pre-line;
  }
  .refill-product__short strong,
  .refill-product__short b { font-weight: 700; }
  .refill-product__short em,
  .refill-product__short i { font-style: italic; }
  .refill-product__short p { margin: 0 0 8px; }
  .refill-product__short p:last-child { margin-bottom: 0; }

  /* Scent label + value (label hardcoded, value from custom.scent metafield) */
  .refill-product__scent {
    margin: 0 0 20px;
    text-align: left;
  }
  .refill-product__scent-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.3;
    letter-spacing: 0.02em;
    text-transform: none;
    color: #000;
    margin: 0 0 6px;
  }
  .refill-product__scent-value {
    display: block;
    font-family: 'Inter', sans-serif;
    font-style: normal;
    font-weight: 500;
    font-size: 14px;
    line-height: 22px;
    letter-spacing: 0;
    color: #000;
    margin: 0;
  }
  .refill-product__scent-value em,
  .refill-product__scent-value i,
  .refill-product__scent-value p:nth-child(n+2) { font-style: italic; }
  .refill-product__scent-value strong,
  .refill-product__scent-value b { font-weight: 700; font-style: italic; }
  .refill-product__scent-value em,
  .refill-product__scent-value i { font-style: italic; }
  .refill-product__scent-value p { margin: 0 0 4px; }
  .refill-product__scent-value p:last-child { margin-bottom: 0; }
  .refill-product__scent-tagline {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #1a1a1a;
    margin: 2px 0 0;
  }

  .refill-product__price-wrap {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 22px;
    line-height: 28px;
    letter-spacing: 0;
    text-align: left;
    margin: 0;
    color: #000;
    display: flex;
    align-items: baseline;
    justify-content: flex-start;
    gap: 10px;
  }
  .refill-product__price-current {
    color: #000;
  }

  .refill-product__price-compare {
    opacity: 0.45;
    font-size: 16px;
    text-decoration: line-through;
    color: #000;
  }

  .refill-product__inventory {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: 0;
    text-align: left;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
    margin: 0 0 24px;
  }

  /* "You selected: Case • Scent" summary — populated client-side from
     localStorage written by case-selector + scent-selector. Hidden until
     at least one selection is present. */
  .refill-product__selection-summary {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0;
    color: #000;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px;
    margin: 0 0 16px;
    padding: 10px 14px;
    background-color: #EDEEF2;
    border-radius: 8px;
  }
  /* The class sets display:flex, which would otherwise override the
     browser's UA `[hidden] { display: none }`, leaving an empty
     "You selected:" pill visible before any selection is made. */
  .refill-product__selection-summary[hidden] {
    display: none;
  }
  .refill-product__selection-label {
    font-weight: 500;
  }
  .refill-product__selection-value {
    font-weight: 400;
  }
  /* Separator is shown by JS only when both case and scent are present. */
  .refill-product__selection-sep {
    color: rgba(0, 0, 0, 0.4);
    display: none;
  }

  .refill-product__inventory-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #b8c0d8;
    flex-shrink: 0;
    position: relative;
    animation: refill-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 0 0 rgba(184, 192, 216, 0.7);
  }

  @keyframes refill-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(184, 192, 216, 0.7); }
    50%  { box-shadow: 0 0 0 7px rgba(184, 192, 216, 0); }
    100% { box-shadow: 0 0 0 0 rgba(184, 192, 216, 0); }
  }

  /* Variant swatches */
  .refill-product__variants {
    margin-bottom: 24px;
  }

  .refill-product__variant-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: 0;
    margin-bottom: 10px;
    text-align: left;
    color: #444;
  }

  .refill-product__swatches {
    display: flex;
    gap: 8px;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .refill-product__swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    outline: 2px solid transparent;
    outline-offset: 2px;
    transition: outline-color 0.2s;
    padding: 0;
    opacity: 0.55;
    filter: saturate(0.4) brightness(1.15);
  }

  .refill-product__swatch.active,
  .refill-product__swatch:hover {
    outline-color: #000;
    opacity: 1;
    filter: saturate(0.4) brightness(1.15);
  }

  /* Buy row */
  .refill-product__buy-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
    margin-bottom: 32px;
  }

  .refill-product__quantity {
    display: flex !important;
    align-items: center !important;
    border: 1.5px solid #000 !important;
    border-radius: 5px !important;
    overflow: hidden !important;
    flex-shrink: 0 !important;
    height: 50px !important;
    background: #fff !important;
    padding: 0 !important;
    gap: 0 !important;
  }

  .refill-product__qty-btn {
    all: unset !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 36px !important;
    height: 100% !important;
    font-size: 16px !important;
    cursor: pointer !important;
    color: #000 !important;
    background: transparent !important;
    border: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    box-shadow: none !important;
    flex-shrink: 0 !important;
  }

  .refill-product__qty-btn:hover {
    background: #f5f5f5 !important;
  }

  .refill-product__qty-input {
    all: unset !important;
    width: 36px !important;
    text-align: center !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 16px !important;
    color: #000 !important;
    background: transparent !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    outline: none !important;
    padding: 0 !important;
    margin: 0 !important;
    height: 100% !important;
  }

  .refill-product__cta {
    flex: 1 1 auto;
    min-width: 0;
    height: 50px;
    background: #363B48;
    color: #FFF8B8;
    border: none;
    border-radius: 5px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 15px;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    padding: 0 32px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .refill-product__cta:hover {
    background: #1f242e;
    color: #FFF8B8;
  }
  .refill-product__cta:focus,
  .refill-product__cta:active {
    color: #FFF8B8;
  }
  /* Make the buy row span the info column so the wider ATC has room. */
  .refill-product__buy-row {
    width: 100%;
  }

  /* Accordion Tabs */
  .refill-product__tabs {
    border-top: none;
    text-align: left;
    margin-top: auto;
  }

  .refill-product__tab {
    border-bottom: 1px solid #000;
  }

  .refill-product__tab-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    cursor: pointer;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    /* iOS Safari shows a blue tap-highlight + treats <button> text as
       link-blue on some sites. Force black + transparent tap color. */
    color: #000;
    -webkit-tap-highlight-color: transparent;
    -webkit-appearance: none;
    appearance: none;
    font: inherit;
  }
  .refill-product__tab-header:focus,
  .refill-product__tab-header:active,
  .refill-product__tab-header:hover {
    color: #000;
    background: none;
  }

  .refill-product__tab-title {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
  }

  .refill-product__tab-icon {
    font-size: 22px;
    line-height: 1;
    transition: transform 0.25s;
    flex-shrink: 0;
    color: #000;
  }

  .refill-product__tab.is-open .refill-product__tab-icon {
    transform: rotate(45deg);
  }

  .refill-product__tab-body {
    display: none;
    padding: 0 0 20px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #1a1a1a;
  }
  .refill-product__tab-body p { margin: 0 0 10px; }
  .refill-product__tab-body p:last-child { margin-bottom: 0; }
  .refill-product__tab-body ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .refill-product__tab-body ul li {
    position: relative;
    padding-left: 22px;
    margin: 0 0 10px;
    line-height: 1.55;
  }
  .refill-product__tab-body ul li:last-child { margin-bottom: 0; }
  .refill-product__tab-body ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #9DBDB0;
  }

  .refill-product__tab.is-open .refill-product__tab-body {
    display: block;
  }

  @media (max-width: 768px) {
    #section-{{ section.id }}.refill-product-section {
      box-sizing: border-box !important;
      width: 100% !important;
      max-width: 100% !important;
      overflow-x: hidden !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
    }
    #section-{{ section.id }} .refill-product__grid {
      grid-template-columns: 1fr !important;
      gap: 20px !important;
      width: 100% !important;
      min-width: 0 !important;
    }
    #section-{{ section.id }} .refill-product__media-col,
    #section-{{ section.id }} .refill-product__info {
      min-width: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }
    /* Mobile: stack as a single column with the MAIN IMAGE on top and
       a horizontal thumbnail strip BELOW the image. Force the main image
       wrap to fill its column edge-to-edge so the image is full-width
       (the section already has a small mobile side margin via
       side_margin_mobile). */
    #section-{{ section.id }} .refill-product__media-col {
      grid-template-columns: 1fr !important;
      gap: 12px !important;
    }
    /* Let the main image keep its natural aspect ratio on mobile so it
       fills the screen edge-to-edge instead of being pillar-boxed inside
       a forced 1:1 square wrap. */
    #section-{{ section.id }} .refill-product__main-image {
      order: 1 !important;
      width: 100% !important;
      margin: 0 !important;
      aspect-ratio: auto !important;
      height: auto !important;
      border-radius: 0 !important;
    }
    /* Show arrows + dot pagination only on mobile, hide thumbnail strip. */
    #section-{{ section.id }} .refill-product__arrow {
      display: flex !important;
    }
    #section-{{ section.id }} .refill-product__dots {
      display: flex !important;
    }
    #section-{{ section.id }} .refill-product__thumbnails {
      display: none !important;
    }
    #section-{{ section.id }} .refill-product__main-image img {
      width: 100% !important;
      height: auto !important;
      object-fit: contain !important;
    }
    #section-{{ section.id }} .refill-product__thumbnails {
      order: 2 !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      overflow-x: auto !important;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 12px 4px !important;
      width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }
    #section-{{ section.id }} .refill-product__thumbnails::-webkit-scrollbar {
      display: none;
    }
    /* Re-pad the info column so text isn't flush against the screen edges
       even though the section root is now padding: 0 on mobile. */
    #section-{{ section.id }} .refill-product__info {
      text-align: left !important;
      padding-left: 16px !important;
      padding-right: 16px !important;
    }
    #section-{{ section.id }} .refill-product__title-price-row {
      flex-direction: column !important;
      align-items: flex-start !important;
      justify-content: flex-start !important;
      gap: 8px !important;
      margin-bottom: 10px !important;
    }
    #section-{{ section.id }} .refill-product__title {
      font-family: 'Inter', sans-serif !important;
      font-weight: 400 !important;
      font-size: 20px !important;
      line-height: 24px !important;
      letter-spacing: 0 !important;
      text-transform: uppercase !important;
      text-align: left !important;
      margin: 0 !important;
    }
    #section-{{ section.id }} .refill-product__price-wrap {
      font-family: 'Inter', sans-serif !important;
      font-weight: 400 !important;
      font-size: 24px !important;
      line-height: 28px !important;
      letter-spacing: 0 !important;
      text-align: left !important;
      margin: 0 !important;
      justify-content: flex-start !important;
    }
    #section-{{ section.id }} .refill-product__price-current {
      font-size: 24px !important;
    }
    #section-{{ section.id }} .refill-product__price-compare {
      font-size: 18px !important;
    }
    #section-{{ section.id }} .refill-product__description {
      font-size: 13px !important;
      line-height: 1.55 !important;
      text-align: left !important;
      margin-bottom: 14px !important;
    }
    #section-{{ section.id }} .refill-product__variants {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: flex-start !important;
      gap: 10px !important;
      margin-bottom: 16px !important;
    }
    #section-{{ section.id }} .refill-product__variant-label {
      margin: 0 !important;
      font-family: 'Inter', sans-serif !important;
      font-weight: 400 !important;
      font-size: 20px !important;
      line-height: 24px !important;
      letter-spacing: 0 !important;
      text-align: left !important;
      white-space: nowrap !important;
    }
    #section-{{ section.id }} .refill-product__swatches {
      justify-content: flex-start !important;
      flex-wrap: nowrap !important;
    }
    #section-{{ section.id }} .refill-product__swatch {
      width: 30px !important;
      height: 30px !important;
      min-width: 30px !important;
      min-height: 30px !important;
      border-radius: 50% !important;
      padding: 0 !important;
      box-sizing: border-box !important;
    }
    #section-{{ section.id }} .refill-product__inventory {
      font-family: 'Inter', sans-serif !important;
      font-weight: 400 !important;
      font-size: 20px !important;
      line-height: 24px !important;
      letter-spacing: 0 !important;
      justify-content: flex-start !important;
      text-align: left !important;
      margin-bottom: 20px !important;
    }
    #section-{{ section.id }} .refill-product__inventory-dot {
      width: 10px !important;
      height: 10px !important;
    }
    #section-{{ section.id }} .refill-product__buy-row {
      display: grid !important;
      grid-template-columns: 110px 1fr !important;
      gap: 20px !important;
      width: 100% !important;
      max-width: 335px !important;
      height: 50px !important;
      margin: 0 0 32px !important;
      align-items: center !important;
    }
    #section-{{ section.id }} .refill-product__quantity {
      width: 110px !important;
      max-width: 110px !important;
      height: 50px !important;
      border-radius: 5px !important;
      border: 1px solid #000 !important;
    }
    #section-{{ section.id }} .refill-product__qty-btn {
      width: 28px !important;
      font-size: 16px !important;
    }
    #section-{{ section.id }} .refill-product__qty-input {
      width: 34px !important;
      font-size: 14px !important;
    }
    #section-{{ section.id }} .refill-product__cta {
      width: 100% !important;
      height: 50px !important;
      border-radius: 5px !important;
      background: #363B48 !important;
      color: #FFF8B8 !important;
      font-size: 14px !important;
      padding: 0 !important;
      box-sizing: border-box !important;
    }
    #section-{{ section.id }} .refill-product__tab-header {
      font-size: 14px !important;
      padding: 14px 0 !important;
    }
    #section-{{ section.id }} .refill-product__tab-body {
      font-size: 13px !important;
    }
  }
</style>

{%- liquid
  assign selected_variant = product.selected_or_first_available_variant
  # Main image = the SECOND product media (skip the first, which is shown
  # as a vertical brand mark above the gallery elsewhere). Falls back to
  # the first media if the product has only one image.
  assign main_media = product.media[1] | default: product.media.first
  assign selected_media = selected_variant.featured_media | default: main_media
  assign low_threshold = section.settings.low_inventory_threshold | default: 10
  assign show_low_inventory = false
  if selected_variant.inventory_management == 'shopify' and selected_variant.inventory_quantity > 0 and selected_variant.inventory_quantity <= low_threshold
    assign show_low_inventory = true
  endif
-%}

<div id="section-{{ section.id }}" class="refill-product-section" style="padding-left: {{ section.settings.padding_horizontal }}px; padding-right: {{ section.settings.padding_horizontal }}px;">
  <div style="max-width: {{ section.settings.max_width }}px; margin: 0 auto;">
    {%- form 'product', product, id: 'refill-product-form', class: 'refill-product__form' -%}
      <input type="hidden" name="id" value="{{ selected_variant.id }}" id="refill-variant-id">

      <div class="refill-product__grid">

        <!-- LEFT: Media (thumbnails column + main image) -->
        <div class="refill-product__media-col">
          {%- if product.media.size > 1 -%}
            <div class="refill-product__thumbnails">
              {%- for media in product.media -%}
                {%- comment -%} Skip the first media — it's already shown as the main image. {%- endcomment -%}
                {%- if forloop.first -%}{%- continue -%}{%- endif -%}
                <div
                  class="refill-product__thumbnail{% if media == selected_media %} active{% endif %}"
                  data-src="{{ media | image_url: width: 900 }}"
                  data-media-id="{{ media.id }}"
                  role="button"
                  tabindex="0"
                  aria-label="{{ media.alt | default: product.title | escape }}"
                >
                  <img
                    src="{{ media | image_url: width: 150 }}"
                    alt="{{ media.alt | default: product.title | escape }}"
                    width="150"
                    height="150"
                    loading="lazy"
                  >
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="refill-product__main-image" id="refill-main-image-{{ section.id }}">
            {%- if selected_media -%}
              <img
                id="refill-featured-img"
                src="{{ selected_media | image_url: width: 900 }}"
                alt="{{ selected_media.alt | default: product.title | escape }}"
                width="900"
                height="900"
                loading="eager"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if product.media.size > 1 -%}
              <button type="button" class="refill-product__arrow refill-product__arrow--prev" aria-label="Previous image">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button type="button" class="refill-product__arrow refill-product__arrow--next" aria-label="Next image">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="refill-product__dots" aria-hidden="true">
                {%- assign total_media = product.media.size -%}
                {%- for i in (1..total_media) -%}
                  <span class="refill-product__dot{% if forloop.first %} active{% endif %}"></span>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

        </div>

        <!-- RIGHT: Info -->
        <div class="refill-product__info">

          <div class="refill-product__title-price-row">
            {%- if section.settings.eyebrow_label != blank -%}
              <p class="refill-product__eyebrow">{{ section.settings.eyebrow_label }}</p>
            {%- endif -%}
            <div class="refill-product__title-row">
              <h1 class="refill-product__title">{{ product.title }}</h1>
              {%- if section.settings.badge_text != blank -%}
                {%- assign badge_bg = product.metafields.custom.badge_color | default: '#BFCED6' -%}
                <span class="refill-product__title-badge" style="background-color: {{ badge_bg }};">{{ section.settings.badge_text }}</span>
              {%- endif -%}
            </div>
            <div class="refill-product__price-wrap" id="refill-price">
              {%- if selected_variant.compare_at_price > selected_variant.price -%}
                <span class="refill-product__price-compare">{{ selected_variant.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="refill-product__price-current">{{ selected_variant.price | money }}</span>
            </div>
          </div>

          {%- comment -%}
            Short description — supports either a plain "Multi-line text"
            metafield or a "Rich text" metafield. metafield_tag handles
            both: plain text renders as text (with newlines preserved),
            rich text renders as nested HTML (paragraphs, bold, italic).
          {%- endcomment -%}
          {%- if product.metafields.custom.short != blank -%}
            <div class="refill-product__short">
              {{ product.metafields.custom.short | metafield_tag }}
            </div>
          {%- endif -%}

          {%- comment -%}
            Scent — same dual handling. The merchant's rich-text typically
            contains 1–2 paragraphs (scent name + tagline); CSS below
            styles them.
          {%- endcomment -%}
          {%- if product.metafields.custom.scent != blank -%}
            <div class="refill-product__scent">
              <span class="refill-product__scent-label">{{ section.settings.scent_label | default: 'SCENT' }}</span>
              <div class="refill-product__scent-value">
                {{ product.metafields.custom.scent | metafield_tag }}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%}
            Hidden inputs preserved so case + scent localStorage selections still
            flow into cart line-item-properties from the case-selector / scent-selector
            sections, even though the visible "You selected:" recap is removed.
          {%- endcomment -%}
          <input type="hidden" name="properties[Case]" id="refill-prop-case" form="refill-product-form" value="">
          <input type="hidden" name="properties[Scent]" id="refill-prop-scent" form="refill-product-form" value="">

          <div class="refill-product__buy-row">
            <div class="refill-product__quantity">
              <button type="button" class="refill-product__qty-btn" id="refill-qty-minus" aria-label="Decrease">−</button>
              <input
                id="refill-qty"
                class="refill-product__qty-input"
                type="text"
                inputmode="numeric"
                pattern="[0-9]*"
                name="quantity"
                value="1"
                aria-label="Quantity"
              >
              <button type="button" class="refill-product__qty-btn" id="refill-qty-plus" aria-label="Increase">+</button>
            </div>
            <button type="submit" name="add" class="refill-product__cta">
              ADD TO CART
            </button>
          </div>

          <div class="refill-product__tabs">
            {%- for block in section.blocks -%}
              {%- if block.type == 'tab' -%}
                <div class="refill-product__tab" {{ block.shopify_attributes }}>
                  <button type="button" class="refill-product__tab-header" aria-expanded="false">
                    <span class="refill-product__tab-title">{{ block.settings.title }}</span>
                    <span class="refill-product__tab-icon" aria-hidden="true">+</span>
                  </button>
                  <div class="refill-product__tab-body">
                    {%- if block.settings.content != blank -%}
                      {{ block.settings.content }}
                    {%- elsif block.settings.page != blank -%}
                      {{ pages[block.settings.page].content }}
                    {%- else -%}
                      <p>Content coming soon.</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

        </div>
      </div>
    {%- endform -%}
  </div>
</div>

<script>
(function () {
  var productVariants = {{ product.variants | json }};

  // Read case + scent selections written by case-selector / scent-selector,
  // surface them in the "You selected" line, and stuff them into hidden
  // line-item-property inputs so they flow into the order.
  function readSelection(key) {
    try {
      var raw = localStorage.getItem(key);
      if (!raw) return null;
      var parsed = JSON.parse(raw);
      if (parsed && typeof parsed.name === 'string' && parsed.name.length) return parsed.name;
    } catch (e) {}
    return null;
  }
  var caseName = readSelection('glozin_selected_case');
  var scentName = readSelection('glozin_selected_scent');
  var casePropInput = document.getElementById('refill-prop-case');
  var scentPropInput = document.getElementById('refill-prop-scent');
  if (casePropInput) casePropInput.value = caseName || '';
  if (scentPropInput) scentPropInput.value = scentName || '';

  // Media gallery — thumbnails, arrows, and swipe
  (function () {
    var sectionRoot = document.getElementById('section-{{ section.id }}');
    if (!sectionRoot) return;
    var thumbs = Array.prototype.slice.call(sectionRoot.querySelectorAll('.refill-product__thumbnail'));
    var img = document.getElementById('refill-featured-img');
    if (!img) return;

    // Build the list of image sources we can navigate through. The thumbs
    // array deliberately skips the first product media (it shows up only
    // as the main image), so we prepend the current main-image src as
    // index 0. Each item is { src, thumbEl }.
    var slides = [{ src: img.src, thumbEl: null }];
    thumbs.forEach(function (t) { slides.push({ src: t.dataset.src, thumbEl: t }); });
    var currentIndex = 0;

    var dots = Array.prototype.slice.call(sectionRoot.querySelectorAll('.refill-product__dot'));

    function goTo(i) {
      if (i < 0) i = slides.length - 1;
      if (i >= slides.length) i = 0;
      currentIndex = i;
      img.src = slides[i].src;
      thumbs.forEach(function (t) { t.classList.remove('active'); });
      if (slides[i].thumbEl) slides[i].thumbEl.classList.add('active');
      dots.forEach(function (d, di) { d.classList.toggle('active', di === i); });
    }

    thumbs.forEach(function (t, idx) {
      t.addEventListener('click', function () { goTo(idx + 1); });
      t.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); goTo(idx + 1); }
      });
    });

    var prevBtn = sectionRoot.querySelector('.refill-product__arrow--prev');
    var nextBtn = sectionRoot.querySelector('.refill-product__arrow--next');
    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(currentIndex - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(currentIndex + 1); });

    // Touch swipe on the main image
    var imageWrap = document.getElementById('refill-main-image-{{ section.id }}');
    if (imageWrap && slides.length > 1) {
      var startX = 0, startY = 0, dx = 0, dy = 0, swiping = false;
      imageWrap.addEventListener('touchstart', function (e) {
        if (e.touches.length !== 1) return;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        dx = 0; dy = 0; swiping = true;
      }, { passive: true });
      imageWrap.addEventListener('touchmove', function (e) {
        if (!swiping || e.touches.length !== 1) return;
        dx = e.touches[0].clientX - startX;
        dy = e.touches[0].clientY - startY;
      }, { passive: true });
      imageWrap.addEventListener('touchend', function () {
        if (!swiping) return;
        swiping = false;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          if (dx < 0) goTo(currentIndex + 1);
          else goTo(currentIndex - 1);
        }
      });
    }
  })();

  // Quantity
  document.getElementById('refill-qty-minus').addEventListener('click', function () {
    var input = document.getElementById('refill-qty');
    var v = parseInt(input.value) || 1;
    if (v > 1) input.value = v - 1;
  });
  document.getElementById('refill-qty-plus').addEventListener('click', function () {
    var input = document.getElementById('refill-qty');
    input.value = (parseInt(input.value) || 1) + 1;
  });

  // Accordion
  document.querySelectorAll('#section-{{ section.id }} .refill-product__tab-header').forEach(function (header) {
    header.addEventListener('click', function () {
      var tab = this.closest('.refill-product__tab');
      var isOpen = tab.classList.contains('is-open');
      document.querySelectorAll('#section-{{ section.id }} .refill-product__tab').forEach(function (t) { t.classList.remove('is-open'); });
      if (!isOpen) tab.classList.add('is-open');
    });
  });

  // Variant picker is removed (color-selector swatches no longer rendered).
  // The hidden variant ID stays at the default (selected_or_first_available_variant)
  // and only changes if you re-introduce a picker later.
})();

// Mobile buy row: force exact sizes via inline styles so no app CSS can override
(function applyMobileBuyRow() {
  if (window.innerWidth > 768) return;
  var root = document.getElementById('section-{{ section.id }}');
  if (!root) return;
  var buyRow = root.querySelector('.refill-product__buy-row');
  var qty    = root.querySelector('.refill-product__quantity');
  var cta    = root.querySelector('.refill-product__cta');
  if (buyRow) {
    buyRow.style.setProperty('display',               'grid',       'important');
    buyRow.style.setProperty('grid-template-columns', '110px 1fr',  'important');
    buyRow.style.setProperty('gap',                   '20px',       'important');
    buyRow.style.setProperty('width',                 '100%',       'important');
    buyRow.style.setProperty('max-width',             '335px',      'important');
    buyRow.style.setProperty('height',                '50px',       'important');
    buyRow.style.setProperty('margin',                '0 0 32px',   'important');
    buyRow.style.setProperty('align-items',           'center',     'important');
  }
  if (qty) {
    qty.style.setProperty('width',         '110px',        'important');
    qty.style.setProperty('max-width',     '110px',        'important');
    qty.style.setProperty('height',        '50px',         'important');
    qty.style.setProperty('border-radius', '5px',          'important');
    qty.style.setProperty('border',        '1px solid #000','important');
  }
  if (cta) {
    cta.style.setProperty('width',         '100%',    'important');
    cta.style.setProperty('height',        '50px',    'important');
    cta.style.setProperty('border-radius', '5px',     'important');
    cta.style.setProperty('background',    '#363B48', 'important');
    cta.style.setProperty('color',         '#FFF8B8', 'important');
    cta.style.setProperty('font-size',     '14px',    'important');
    cta.style.setProperty('padding',       '0',       'important');
    cta.style.setProperty('box-sizing',    'border-box','important');
  }
})();
</script>

{% schema %}
{
  "name": "Refill Product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section max width (px)",
      "min": 600,
      "max": 1600,
      "step": 20,
      "default": 1200
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between media & info columns (px)",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "media_col_fr",
      "label": "Media column width",
      "info": "Relative width of the left (media) column. Larger value = wider media column.",
      "min": 50,
      "max": 200,
      "step": 5,
      "default": 115
    },
    {
      "type": "range",
      "id": "info_col_fr",
      "label": "Info column width",
      "info": "Relative width of the right (info) column. Larger value = wider info column.",
      "min": 50,
      "max": 200,
      "step": 5,
      "default": 100
    },
    {
      "type": "header",
      "content": "Side margins"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Side margin – Desktop (px)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "side_margin_mobile",
      "label": "Side margin – Mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "ADD TO CART"
    },
    {
      "type": "text",
      "id": "eyebrow_label",
      "label": "Eyebrow text (above title)",
      "info": "Small uppercase text shown above the product title.",
      "default": "REFILLABLE DEODORANT POD"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Title badge text",
      "info": "Small badge to the right of the title (e.g. \"45G\"). Leave empty to hide.",
      "default": "45G"
    },
    {
      "type": "text",
      "id": "scent_label",
      "label": "Scent section label",
      "default": "SCENT"
    },
    {
      "type": "range",
      "id": "main_image_size_pct",
      "label": "Main image size",
      "info": "Percent of the main-image column. Lower values make the image smaller and add side margin.",
      "default": 100,
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "main_image_radius",
      "label": "Main image corner radius",
      "default": 15,
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "main_image_height_px",
      "label": "Main image height (px)",
      "info": "0 = auto (matches the thumbnail column height). Set a value to lock the image to a specific pixel height.",
      "default": 0,
      "min": 0,
      "max": 900,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "thumbnail_height_px",
      "label": "Thumbnail height (px)",
      "default": 80,
      "min": 40,
      "max": 160,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "thumbnail_gap_px",
      "label": "Gap between thumbnails (px)",
      "default": 8,
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "paragraph",
      "content": "Short description renders from the product metafield custom.short (multi-line text). Scent renders from custom.scent (text). Both must be defined in Settings → Custom data → Products."
    },
    {
      "type": "number",
      "id": "low_inventory_threshold",
      "label": "Low Inventory Threshold",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Title",
          "default": "Tab"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Tab Content"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Or link a page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Refill Product",
      "blocks": [
        { "type": "tab", "settings": { "title": "TECHNICAL INFO" } },
        { "type": "tab", "settings": { "title": "HOW TO APPLY" } },
        { "type": "tab", "settings": { "title": "INGREDIENTS" } }
      ]
    }
  ]
}
{% endschema %}
