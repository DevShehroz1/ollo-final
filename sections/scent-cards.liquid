      "label": "Point label size — Desktop",
      "default": 16,
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "point_label_size_mobile",
      "label": "Point label size — Mobile",
      "default": 14,
      "min": 9,
      "max": 24,
      "step": 1,
      "unit": "px"
    },
