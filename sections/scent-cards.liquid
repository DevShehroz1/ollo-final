    },
    {
      "type": "range",
      "id": "point_text_size_mobile",
      "label": "Point description size — Mobile",
      "default": 16,
      "min": 10,
      "max": 26,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_line_height_desktop",
      "label": "Card heading line height — Desktop",
      "default": 28,
      "min": 14,
      "max": 60,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_line_height_mobile",
      "label": "Card heading line height — Mobile",
      "default": 24,
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "point_label_line_height_desktop",
      "label": "Point label line height — Desktop",
      "default": 19,
      "min": 12,
      "max": 40,
      "step": 1,
