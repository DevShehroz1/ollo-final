{%- liquid
  assign sec_id = section.id
  assign interval_ms = section.settings.autorotate_seconds | times: 1000
-%}

<section
  class="trust-icon-bar"
  data-trust-icon-bar="{{ sec_id }}"
  data-interval="{{ interval_ms }}"
  style="
    --tib-bg: {{ section.settings.bg_color }};
    --tib-text: {{ section.settings.text_color }};
    --tib-icon-desktop: {{ section.settings.icon_size_desktop }}px;
    --tib-icon-mobile: {{ section.settings.icon_size_mobile }}px;
    --tib-label-desktop: {{ section.settings.heading_size_desktop }}px;
    --tib-label-mobile: {{ section.settings.heading_size_mobile }}px;
    --tib-gap-desktop: {{ section.settings.gap_desktop }}px;
    --tib-icon-label-gap: {{ section.settings.icon_label_gap }}px;
    --tib-pad-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --tib-pad-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --tib-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --tib-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --tib-pad-h-desktop: {{ section.settings.padding_h_desktop }}px;
    --tib-pad-h-mobile: {{ section.settings.padding_h_mobile }}px;
  "
>
  <div class="trust-icon-bar__inner">
    {%- for block in section.blocks -%}
      {%- assign has_link = false -%}
      {%- if block.settings.link != blank -%}{%- assign has_link = true -%}{%- endif -%}
      {%- capture inner -%}
        {%- if block.settings.icon != blank -%}
          <span class="trust-icon-bar__icon">
            {{ block.settings.icon | image_url: width: 160 | image_tag:
              loading: 'lazy',
              widths: '40, 80, 120, 160',
              sizes: '(min-width: 768px) 60px, 44px',
              alt: block.settings.heading
            }}
          </span>
        {%- endif -%}
        <span class="trust-icon-bar__label">{{ block.settings.heading }}</span>
      {%- endcapture -%}
      {%- if has_link -%}
        <a
          class="trust-icon-bar__item"
          href="{{ block.settings.link }}"
          {{ block.shopify_attributes }}
        >{{ inner }}</a>
      {%- else -%}
        <div class="trust-icon-bar__item" {{ block.shopify_attributes }}>{{ inner }}</div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="trust-icon-bar__dots" aria-hidden="true">
      {%- for block in section.blocks -%}
        <span class="trust-icon-bar__dot" data-index="{{ forloop.index0 }}"></span>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .trust-icon-bar {
    background: var(--tib-bg);
    color: var(--tib-text);
    padding-top: var(--tib-pad-top-desktop);
    padding-bottom: var(--tib-pad-bottom-desktop);
    padding-left: var(--tib-pad-h-desktop);
    padding-right: var(--tib-pad-h-desktop);
  }

  .trust-icon-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--tib-gap-desktop);
    max-width: 1440px;
    margin: 0 auto;
  }

  .trust-icon-bar__item {
    display: inline-flex;
    align-items: center;
    gap: var(--tib-icon-label-gap);
    color: inherit;
    text-decoration: none;
    flex: 1 1 0;
    justify-content: center;
    line-height: 1.25;
    transition: opacity 0.2s ease;
  }
  .trust-icon-bar__item:hover { opacity: 0.7; }

  .trust-icon-bar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: var(--tib-icon-desktop);
    height: var(--tib-icon-desktop);
  }
  .trust-icon-bar__icon img,
  .trust-icon-bar__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .trust-icon-bar__label {
    font-size: var(--tib-label-desktop);
    font-weight: 600;
    color: inherit;
    white-space: normal;
  }

  .trust-icon-bar__dots { display: none; }

  @media (max-width: 767.98px) {
    .trust-icon-bar {
      padding-top: var(--tib-pad-top-mobile);
      padding-bottom: var(--tib-pad-bottom-mobile);
      padding-left: var(--tib-pad-h-mobile);
      padding-right: var(--tib-pad-h-mobile);
    }
    .trust-icon-bar__inner {
      display: block;
      position: relative;
      min-height: calc(var(--tib-icon-mobile) + 12px);
    }
    .trust-icon-bar__item {
      display: none;
      justify-content: center;
      gap: 12px;
    }
    .trust-icon-bar__item.is-active {
      display: inline-flex;
      width: 100%;
      animation: trustIconBarFade 0.45s ease both;
    }
    .trust-icon-bar__icon {
      width: var(--tib-icon-mobile);
      height: var(--tib-icon-mobile);
    }
    .trust-icon-bar__label {
      font-size: var(--tib-label-mobile);
    }
    .trust-icon-bar__dots {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-top: 12px;
    }
    .trust-icon-bar__dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: currentColor;
      opacity: 0.25;
      transition: opacity 0.2s ease;
    }
    .trust-icon-bar__dot.is-active { opacity: 0.9; }
  }

  @keyframes trustIconBarFade {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
{% endstylesheet %}

<script>
  (function() {
    var root = document.querySelector('[data-trust-icon-bar="{{ sec_id }}"]');
    if (!root) return;
    var items = root.querySelectorAll('.trust-icon-bar__item');
    var dots = root.querySelectorAll('.trust-icon-bar__dot');
    if (items.length <= 1) return;

    var interval = parseInt(root.getAttribute('data-interval'), 10) || 4000;
    var mobileQuery = window.matchMedia('(max-width: 767.98px)');
    var idx = 0;
    var timer = null;

    function paint(i) {
      for (var j = 0; j < items.length; j++) {
        items[j].classList.toggle('is-active', i === j);
      }
      for (var k = 0; k < dots.length; k++) {
        dots[k].classList.toggle('is-active', i === k);
      }
    }

    function tick() {
      idx = (idx + 1) % items.length;
      paint(idx);
    }

    function start() {
      stop();
      if (!mobileQuery.matches) return;
      idx = 0;
      paint(idx);
      timer = window.setInterval(tick, interval);
    }

    function stop() {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
      if (!mobileQuery.matches) {
        for (var j = 0; j < items.length; j++) items[j].classList.remove('is-active');
        for (var k = 0; k < dots.length; k++) dots[k].classList.remove('is-active');
      }
    }

    start();

    if (mobileQuery.addEventListener) {
      mobileQuery.addEventListener('change', start);
    } else if (mobileQuery.addListener) {
      mobileQuery.addListener(start);
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail && e.detail.sectionId === '{{ sec_id }}') start();
    });
    document.addEventListener('shopify:section:unload', function(e) {
      if (e.detail && e.detail.sectionId === '{{ sec_id }}') stop();
    });
  })();
</script>

{% schema %}
{
  "name": "Trust icon bar",
  "tag": "section",
  "class": "section section-trust-icon-bar",
  "settings": [
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "bg_color", "default": "#F3F4F3", "label": "Background color" },
    { "type": "color", "id": "text_color", "default": "#111111", "label": "Text color" },

    { "type": "header", "content": "Icons" },
    { "type": "range", "id": "icon_size_desktop", "min": 24, "max": 80, "step": 2, "default": 44, "unit": "px", "label": "Desktop icon size" },
    { "type": "range", "id": "icon_size_mobile", "min": 24, "max": 80, "step": 2, "default": 36, "unit": "px", "label": "Mobile icon size" },
    { "type": "range", "id": "icon_label_gap", "min": 4, "max": 40, "step": 2, "default": 14, "unit": "px", "label": "Gap between icon and label" },

    { "type": "header", "content": "Label" },
    { "type": "range", "id": "heading_size_desktop", "min": 12, "max": 24, "step": 1, "default": 16, "unit": "px", "label": "Desktop label size" },
    { "type": "range", "id": "heading_size_mobile", "min": 12, "max": 24, "step": 1, "default": 16, "unit": "px", "label": "Mobile label size" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "gap_desktop", "min": 0, "max": 80, "step": 2, "default": 24, "unit": "px", "label": "Desktop gap between badges" },

    { "type": "header", "content": "Mobile carousel" },
    { "type": "range", "id": "autorotate_seconds", "min": 2, "max": 10, "step": 1, "default": 4, "unit": "s", "label": "Auto-rotate every", "info": "Mobile only. One badge at a time." },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 80, "step": 2, "default": 28, "unit": "px", "label": "Desktop padding top" },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 80, "step": 2, "default": 28, "unit": "px", "label": "Desktop padding bottom" },
    { "type": "range", "id": "padding_h_desktop", "min": 0, "max": 80, "step": 2, "default": 32, "unit": "px", "label": "Desktop horizontal padding" },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 60, "step": 2, "default": 18, "unit": "px", "label": "Mobile padding top" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 60, "step": 2, "default": 18, "unit": "px", "label": "Mobile padding bottom" },
    { "type": "range", "id": "padding_h_mobile", "min": 0, "max": 40, "step": 2, "default": 16, "unit": "px", "label": "Mobile horizontal padding" }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust badge",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon (PNG or SVG)" },
        { "type": "text", "id": "heading", "default": "Trust message", "label": "Label" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Trust icon bar",
      "category": "Promotional",
      "blocks": [
        { "type": "badge", "settings": { "heading": "30 Years in Business" } },
        { "type": "badge", "settings": { "heading": "Worldwide Shipping" } },
        { "type": "badge", "settings": { "heading": "Visit our Melbourne Store" } },
        { "type": "badge", "settings": { "heading": "Free Gift Wrapping" } },
        { "type": "badge", "settings": { "heading": "100k+ Happy Customers" } }
      ]
    }
  ]
}
{% endschema %}
