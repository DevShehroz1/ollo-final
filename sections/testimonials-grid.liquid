<style>
  .testimonials-grid {
    padding-top: var(--section-pt, 60px);
    padding-bottom: var(--section-pb, 60px);
  }
  .testimonials-grid .testimonials-grid__inner {
    width: 100%;
    max-width: 1680px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .testimonials-grid .testimonials-grid__heading {
    font-family: 'Inter', var(--heading-font), sans-serif;
    font-weight: 500;
    font-style: normal;
    font-size: 46px;
    line-height: 50px;
    letter-spacing: -1.12px;
    text-align: center;
    text-transform: uppercase;
    margin: 0 0 50px;
    padding: 0;
    color: var(--color-foreground, #000);
  }
  /* Desktop/tablet (>=768px): keep the original grid layout, neutralize Swiper base styles */
  @media (min-width: 768px) {
    /* Heading uses \`|\` as a mobile-only line break — convert to <br>
       in Liquid, then hide the <br> on desktop so the heading stays
       on one line. */
    .testimonials-grid .testimonials-grid__heading br {
      display: none;
    }
    .testimonials-grid .testimonials-grid__items.swiper {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 64px;
      overflow: visible;
      position: static;
    }
    .testimonials-grid .testimonials-grid__items.swiper > .swiper-wrapper {
      display: contents;
    }
    .testimonials-grid .testimonials-grid__items.swiper .swiper-slide {
      display: block;
      width: auto;
      height: auto;
      flex-shrink: initial;
    }
    .testimonials-grid .testimonials-grid__items.swiper .testimonials-grid__pagination {
      display: none;
    }
  }
  .testimonials-grid .testimonials-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 64px;
  }
  .testimonials-grid .testimonials-grid__items .swiper-slide {
    position: relative;
  }
  .testimonials-grid .testimonials-grid__item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    padding: 0 12px;
    height: auto;
    width: 100%;
  }
  .testimonials-grid .testimonials-grid__items .swiper-slide:not(:last-child) .testimonials-grid__item::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -32px;
    transform: translateY(-50%);
    width: 1px;
    height: 196.98px;
    opacity: 1;
    background-color: #EDEEF2;
  }
  .testimonials-grid .testimonials-grid__stars {
    display: inline-flex;
    gap: 6px;
    margin: 0 0 18px;
    color: #A6BDDD;
    font-size: 14px;
    line-height: 1;
  }
  .testimonials-grid .testimonials-grid__stars svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    display: block;
  }
  .testimonials-grid .testimonials-grid__text {
    font-family: 'Inter', var(--body-font), sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 14px;
    line-height: 18px;
    letter-spacing: 0;
    text-align: center;
    color: var(--color-foreground, #000);
    margin: 0 0 22px;
    padding: 0;
    max-width: 280px;
  }
  .testimonials-grid .testimonials-grid__name {
    font-family: 'Inter', var(--heading-font), sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 20px;
    line-height: 22px;
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;
    color: var(--color-foreground, #000);
    margin: 0;
    padding: 0;
  }
  @media (min-width: 768px) and (max-width: 991.98px) {
    .testimonials-grid .testimonials-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 20px;
    }
    .testimonials-grid .testimonials-grid__items .swiper-slide:not(:last-child) .testimonials-grid__item::after {
      display: none;
    }
  }
  /* Mobile carousel (<=767.98px): Swiper takes over and disables the grid layout */
  @media (max-width: 767.98px) {
    .testimonials-grid .testimonials-grid__heading {
      font-size: 30px;
      line-height: 34px;
      letter-spacing: -0.5px;
      margin-bottom: 32px;
    }
    .testimonials-grid .testimonials-grid__items.swiper {
      display: block;
      overflow: hidden;
      padding-bottom: 0;
    }
    .testimonials-grid .testimonials-grid__items.swiper .swiper-wrapper {
      display: flex;
      align-items: stretch;
    }
    .testimonials-grid .testimonials-grid__items.swiper .swiper-slide {
      height: auto;
      display: flex;
    }
    .testimonials-grid .testimonials-grid__items .swiper-slide:not(:last-child) .testimonials-grid__item::after {
      display: none;
    }
    .testimonials-grid .testimonials-grid__item {
      width: 100%;
      padding: 0 8px;
    }
    /* Modern "dash" pagination: thin horizontal pills, active pill expands */
    .testimonials-grid .testimonials-grid__pagination.swiper-pagination {
      position: relative;
      left: auto;
      right: auto;
      bottom: auto;
      top: auto;
      width: 100%;
      height: auto;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      margin: 28px 0 0;
      padding: 0;
      line-height: 0;
      transform: none;
    }
    .testimonials-grid .testimonials-grid__pagination .swiper-pagination-bullet {
      width: 18px;
      height: 3px;
      min-width: 18px;
      min-height: 3px;
      max-width: none;
      max-height: none;
      padding: 0;
      margin: 0;
      border: 0;
      border-radius: 999px;
      background-color: #D4D4D4;
      opacity: 1;
      display: inline-block;
      position: relative;
      overflow: hidden;
      transform: none;
      transition: width 0.35s ease, min-width 0.35s ease, background-color 0.25s ease;
      cursor: pointer;
    }
    /* Neutralize the theme-wide ::before decoration (the ::after is repurposed below as the progress fill) */
    .testimonials-grid .testimonials-grid__pagination .swiper-pagination-bullet::before {
      content: none;
      display: none;
    }
    .testimonials-grid .testimonials-grid__pagination .swiper-pagination-bullet::after {
      content: none;
      display: none;
    }
    .testimonials-grid .testimonials-grid__pagination .swiper-pagination-bullet:hover {
      background-color: #A0A0A0;
    }
    /* Active pill: grey track with a dark progress fill driven by Swiper's autoplayTimeLeft via --tg-progress */
    .testimonials-grid .testimonials-grid__pagination .swiper-pagination-bullet-active {
      width: 36px;
      min-width: 36px;
      background-color: #D4D4D4;
      transform: none;
    }
    .testimonials-grid .testimonials-grid__pagination .swiper-pagination-bullet-active::after {
      content: "";
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      width: auto;
      height: auto;
      background-color: var(--color-foreground, #000);
      transform-origin: left center;
      transform: scaleX(var(--tg-progress, 0));
      border-radius: inherit;
      transition: none;
    }
    .testimonials-grid__inner {
      position: relative;
    }
  }
</style>
{%- liquid
  assign sec_st = section.settings
-%}
<div
  id="testimonials-grid-{{ section.id }}"
  class="testimonials-grid color-{{ sec_st.color_scheme }} gradient"
  style="--section-pt: {{ sec_st.padding_top }}px; --section-pb: {{ sec_st.padding_bottom }}px;"
>
  <div class="testimonials-grid__inner">
    {%- if sec_st.heading != blank -%}
      <h2 class="testimonials-grid__heading">{{ sec_st.heading | replace: '|', '<br>' }}</h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="testimonials-grid__items swiper" data-testimonials-carousel>
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            {%- liquid
              assign b = block.settings
              assign rating = b.rating | default: 5
            -%}
            <div class="swiper-slide">
              <div class="testimonials-grid__item" {{ block.shopify_attributes }}>
                <div class="testimonials-grid__stars" aria-label="{{ rating }} out of 5 stars">
                  {%- for i in (1..5) -%}
                    {%- if i <= rating -%}
                      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0l2.09 5.36L16 6.12l-4.46 3.86L12.98 16 8 13.1 3.02 16l1.44-6.02L0 6.12l5.91-.76L8 0z"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 16 16" aria-hidden="true" style="opacity:0.25"><path d="M8 0l2.09 5.36L16 6.12l-4.46 3.86L12.98 16 8 13.1 3.02 16l1.44-6.02L0 6.12l5.91-.76L8 0z"/></svg>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- if b.text != blank -%}
                  <div class="testimonials-grid__text">{{ b.text }}</div>
                {%- endif -%}
                {%- if b.name != blank -%}
                  <div class="testimonials-grid__name">{{ b.name }}</div>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
        <div class="testimonials-grid__pagination swiper-pagination" data-testimonials-pagination></div>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var sectionEl = document.getElementById('testimonials-grid-' + sectionId);
    if (!sectionEl) return;
    var container = sectionEl.querySelector('[data-testimonials-carousel]');
    var paginationEl = sectionEl.querySelector('[data-testimonials-pagination]');
    if (!container) return;

    var instance = null;
    var MOBILE_MAX = 767.98;
    var mq = window.matchMedia('(max-width: ' + MOBILE_MAX + 'px)');

    function setProgress(p) {
      if (!paginationEl) return;
      var clamped = Math.max(0, Math.min(1, p));
      paginationEl.style.setProperty('--tg-progress', clamped);
    }

    function initSwiper() {
      if (instance || typeof window.Swiper === 'undefined') return;
      instance = new window.Swiper(container, {
        slidesPerView: 1,
        spaceBetween: 0,
        centeredSlides: false,
        watchOverflow: true,
        loop: true,
        speed: 500,
        autoplay: {
          delay: 4000,
          disableOnInteraction: false,
          pauseOnMouseEnter: false,
        },
        pagination: {
          el: paginationEl,
          clickable: true,
          bulletClass: 'swiper-pagination-bullet',
          bulletActiveClass: 'swiper-pagination-bullet-active',
        },
        on: {
          init: function () { setProgress(0); },
          slideChangeTransitionStart: function () { setProgress(0); },
          // Swiper emits autoplayTimeLeft every frame while autoplay is running.
          // percentage: 1 = just started, 0 = about to advance. Invert for "filled" progress.
          autoplayTimeLeft: function (s, timeLeft, percentage) {
            setProgress(1 - percentage);
          },
          autoplayStop: function () { setProgress(0); },
        },
      });
    }

    function destroySwiper() {
      if (instance) {
        instance.destroy(true, true);
        instance = null;
      }
    }

    function handle(e) {
      if (e.matches) {
        initSwiper();
      } else {
        destroySwiper();
      }
    }

    function ready(fn) {
      if (document.readyState !== 'loading') {
        fn();
      } else {
        document.addEventListener('DOMContentLoaded', fn);
      }
    }

    ready(function () {
      if (mq.matches) initSwiper();
      if (typeof mq.addEventListener === 'function') {
        mq.addEventListener('change', handle);
      } else if (typeof mq.addListener === 'function') {
        mq.addListener(handle);
      }
    });

    // Re-init when Shopify theme editor reloads/selects the section
    document.addEventListener('shopify:section:load', function (evt) {
      if (evt && evt.detail && evt.detail.sectionId === sectionId) {
        destroySwiper();
        if (mq.matches) initSwiper();
      }
    });
    document.addEventListener('shopify:section:unload', function (evt) {
      if (evt && evt.detail && evt.detail.sectionId === sectionId) {
        destroySwiper();
      }
    });
  })();
</script>
{% schema %}
{
  "name": "Testimonials Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Use the | character to force a line break on mobile only (e.g. \"TRIED,|TESTED AND TRUSTED\" → \"TRIED,\" on line 1, rest on line 2 below 768px).",
      "default": "TRIED, TESTED AND TRUSTED"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "limit": 12,
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating (stars)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "I never thought about fragrance actually doing something. Now I can't go back."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "ADITI, MUMBAI"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Grid",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "I never thought about fragrance actually doing something. Now I can't go back.",
            "name": "ADITI, MUMBAI"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "It's so light you forget you're wearing it. Then you realise you've felt fresh all day.",
            "name": "ROHAN, BENGALURU"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Came for the refill idea. The scent made me stay.",
            "name": "NEHA, DELHI"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "First deodorant that actually lasts through Mumbai humidity.",
            "name": "VIMAL, MUMBAI"
          }
        }
      ]
    }
  ]
}
{% endschema %}
