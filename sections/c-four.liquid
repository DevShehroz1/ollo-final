{%- capture style -%}
  --section-pt: {{ section.settings.padding_top }}; --section-pb: {{ section.settings.padding_bottom }};
{%- endcapture -%}
<div
  class="section{% if section.settings.padding_top < 30 %} pt-min{% endif %}{% if section.settings.padding_bottom < 30 %} pb-min{% endif %}"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="fluid_container">
    <div class="c-four__grid">
      {%- for block in section.blocks -%}
        <div class="c-four__item" {{ block.shopify_attributes }}>
          <div class="c-four__icon">
            <img
              src="https://cdn.shopify.com/s/files/1/0778/7482/3353/files/starstud_1.webp?v=1774875236"
              alt="star"
              width="40"
              height="40"
              loading="lazy"
            >
          </div>
          {%- if block.settings.heading != blank -%}
            <h3 class="c-four__heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="c-four__desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .c-four__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .c-four__item {
    text-align: center;
    padding: 20px 30px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .c-four__item:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    width: 1px;
    height: 80%;
    background-color: #EDEEF2;
  }
  .c-four__icon {
    margin-bottom: 15px;
  }
  .c-four__icon img {
    width: 40px;
    height: 40px;
    display: inline-block;
  }
  .c-four__heading {
    font-family: var(--heading-font);
    font-size: 21.6px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin: 0 0 6px 0;
    color: #000;
    min-height: 2.4em;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .c-four__desc {
    font-family: var(--body-font);
    font-size: 16px;
    font-weight: 400;
    color: #333333;
    line-height: 1.5;
    margin: 6px 0 0 0;
  }
  @media (max-width: 767px) {
    .c-four__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      margin: 0 -15px;
      width: calc(100% + 30px);
    }
    .c-four__item {
      padding: 25px 15px;
    }
    .c-four__item:nth-child(odd) {
      border-right: 1px solid #EDEEF2;
    }
    .c-four__item:nth-child(1),
    .c-four__item:nth-child(2) {
      border-bottom: 1px solid #EDEEF2;
    }
    .c-four__item:not(:last-child)::after {
      display: none;
    }
    .c-four__heading {
      font-size: 18px;
    }
    .c-four__desc {
      font-size: 14px;
    }
  }
  @media (min-width: 768px) and (max-width: 1024px) {
    .c-four__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      border-top: 1px solid #EDEEF2;
      border-left: 1px solid #EDEEF2;
    }
    .c-four__item {
      border-right: 1px solid #EDEEF2;
      border-bottom: 1px solid #EDEEF2;
    }
    .c-four__item:not(:last-child)::after {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "C Four",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Description text goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Four",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "heading": "Skin-First Formulas",
            "description": "Makeup that treats your skin while you wear it."
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Inclusive Shades",
            "description": "Made to work across tones and undertones."
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Multi-Use Essentials",
            "description": "Minimal effort. Maximum options."
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Clean & Conscious",
            "description": "Vegan. Cruelty-free. Thoughtfully formulated."
          }
        }
      ]
    }
  ]
}
{% endschema %}
