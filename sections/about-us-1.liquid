{{ 'banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sec_st = section.settings
  assign section_width = sec_st.section_width
  assign image = sec_st.image
  assign image_mobile = sec_st.image_mobile | default: image
  if sec_st.reset_spacing
    assign reset_spacing = ' remove_spacing'
  endif
  assign overlay_style = sec_st.overlay_style | default: 'none'
  assign overlay_opacity = sec_st.overlay_opacity | default: 0
-%}
{%- capture style -%}
  --section-pt: {{ sec_st.padding_top }}; --section-pb: {{ sec_st.padding_bottom }};
  --height: {{ sec_st.mobile_height }}px; --height-desktop: {{ sec_st.desktop_height }}px;
{%- endcapture -%}
<div
  class="section{% if sec_st.padding_top < 30 %} pt-min{% endif %}{% if sec_st.padding_bottom < 30 %} pb-min{% endif %} about-us-1{{ reset_spacing }}"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="{{ section_width }}">
    <div class="sec__inner about-us-1__inner flex relative h-custom overflow-hidden">
      <div
        class="banner__media about-us-1__media w-full{% if overlay_style != 'none' %} overlay-bg{% endif %} absolute inset-0"
        style="--point: {{ image.presentation.focal_point }};"
      >
        {%- if image != blank -%}
          {%- assign image_alt = image.alt | default: sec_st.heading -%}
          {% render 'responsive-image',
            type: 'banner',
            container: section_width,
            image: image,
            image_mobile: image_mobile,
            image_alt: image_alt
          %}
        {%- else -%}
          {%- render 'placeholder-render', class: 'absolute inset-0 w-full h-full object-fit-cover' -%}
        {%- endif -%}
      </div>

      {%- if sec_st.heading != blank -%}
        <div class="about-us-1__heading-wrap absolute z-1 flex">
          <{{ sec_st.heading_tag }} class="about-us-1__heading mt-0 mb-0">
            {{ sec_st.heading }}
          </{{ sec_st.heading_tag }}>
        </div>
      {%- endif -%}

      {%- if sec_st.description != blank -%}
        <div class="about-us-1__desc-wrap absolute z-1 flex">
          <div class="about-us-1__desc">
            {{ sec_st.description }}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% style %}
  /* ----- Media + overlay ----- */
  #shopify-section-{{ section.id }} .about-us-1__media img,
  #shopify-section-{{ section.id }} .about-us-1__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  {%- if overlay_style == 'light' -%}
    #shopify-section-{{ section.id }} .overlay-bg:after {
      background-color: #ffffff;
      opacity: {{ overlay_opacity }}%;
    }
  {%- elsif overlay_style == 'dark' -%}
    #shopify-section-{{ section.id }} .overlay-bg:after {
      background-color: #000000;
      opacity: {{ overlay_opacity }}%;
    }
  {%- endif -%}

  /* ----- Heading: centered both axes ----- */
  #shopify-section-{{ section.id }} .about-us-1__heading-wrap {
    inset: 0;
    align-items: center;
    justify-content: center;
    padding: {{ sec_st.heading_padding_y_desktop }}px {{ sec_st.heading_padding_x_desktop }}px;
    transform: translateY({{ sec_st.heading_offset_y_desktop }}px);
    box-sizing: border-box;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .about-us-1__heading {
    color: {{ sec_st.heading_color }};
    text-align: center;
    max-width: {{ sec_st.heading_max_width_desktop }}px;
    font-family: {{ sec_st.heading_font_family | default: "'Inter', sans-serif" }};
    font-size: {{ sec_st.heading_font_size_desktop }}px;
    line-height: {{ sec_st.heading_line_height_desktop }}px;
    font-weight: {{ sec_st.heading_font_weight }};
    letter-spacing: {{ sec_st.heading_letter_spacing_desktop }}px;
    word-spacing: {{ sec_st.heading_word_spacing_desktop }}px;
    pointer-events: auto;
    {%- case sec_st.heading_case -%}
      {%- when 'uppercase' -%}text-transform: uppercase;
      {%- when 'lowercase' -%}text-transform: lowercase;
      {%- when 'capitalize' -%}text-transform: capitalize;
      {%- when 'sentence' -%}text-transform: lowercase;
      {%- else -%}text-transform: none;
    {%- endcase -%}
  }
  {%- if sec_st.heading_case == 'sentence' -%}
  #shopify-section-{{ section.id }} .about-us-1__heading::first-letter {
    text-transform: uppercase;
  }
  {%- endif -%}
  #shopify-section-{{ section.id }} .about-us-1__heading :is(b, strong) {
    color: inherit;
    font-weight: 600;
  }
  #shopify-section-{{ section.id }} .about-us-1__heading :is(i, em) {
    color: inherit;
  }
  #shopify-section-{{ section.id }} .about-us-1__heading br {
    display: inline;
  }

  /* ----- Description: bottom center, text-align left ----- */
  #shopify-section-{{ section.id }} .about-us-1__desc-wrap {
    left: 0;
    right: 0;
    bottom: 0;
    align-items: flex-end;
    justify-content: center;
    padding: 0 {{ sec_st.desc_padding_x_desktop }}px {{ sec_st.desc_bottom_offset_desktop }}px;
    box-sizing: border-box;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .about-us-1__desc {
    color: {{ sec_st.description_color }};
    text-align: left;
    max-width: {{ sec_st.desc_max_width_desktop }}px;
    width: 100%;
    font-family: {{ sec_st.description_font_family | default: "'Inter', sans-serif" }};
    font-size: {{ sec_st.description_font_size_desktop }}px;
    line-height: {{ sec_st.description_line_height_desktop }}px;
    font-weight: {{ sec_st.description_font_weight }};
    letter-spacing: {{ sec_st.description_letter_spacing_desktop }}px;
    word-spacing: {{ sec_st.description_word_spacing_desktop }}px;
    pointer-events: auto;
  }
  #shopify-section-{{ section.id }} .about-us-1__desc p {
    margin-top: 0;
    margin-bottom: {{ sec_st.desc_paragraph_spacing_desktop }}px;
  }
  #shopify-section-{{ section.id }} .about-us-1__desc > *:first-child { margin-top: 0; }
  #shopify-section-{{ section.id }} .about-us-1__desc > *:last-child  { margin-bottom: 0; }

  /* ----- Mobile ----- */
  @media (max-width: 767.98px) {
    #shopify-section-{{ section.id }} .about-us-1__heading-wrap {
      padding: {{ sec_st.heading_padding_y_mobile }}px {{ sec_st.heading_padding_x_mobile }}px;
      transform: translateY({{ sec_st.heading_offset_y_mobile }}px);
    }
    #shopify-section-{{ section.id }} .about-us-1__heading {
      max-width: {{ sec_st.heading_max_width_mobile }}px;
      font-size: {{ sec_st.heading_font_size_mobile }}px;
      line-height: {{ sec_st.heading_line_height_mobile }}px;
      letter-spacing: {{ sec_st.heading_letter_spacing_mobile }}px;
      word-spacing: {{ sec_st.heading_word_spacing_mobile }}px;
    }
    #shopify-section-{{ section.id }} .about-us-1__desc-wrap {
      padding: 0 {{ sec_st.desc_padding_x_mobile }}px {{ sec_st.desc_bottom_offset_mobile }}px;
    }
    #shopify-section-{{ section.id }} .about-us-1__desc {
      max-width: {{ sec_st.desc_max_width_mobile }}px;
      font-size: {{ sec_st.description_font_size_mobile }}px;
      line-height: {{ sec_st.description_line_height_mobile }}px;
      letter-spacing: {{ sec_st.description_letter_spacing_mobile }}px;
      word-spacing: {{ sec_st.description_word_spacing_mobile }}px;
      text-align: center;
    }
    #shopify-section-{{ section.id }} .about-us-1__desc p {
      margin-bottom: {{ sec_st.desc_paragraph_spacing_mobile }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "About Us 1",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "full_width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "fluid_container", "label": "Fluid container" },
        { "value": "stretch_width", "label": "Stretch width" },
        { "value": "full_width", "label": "Full width" }
      ]
    },

    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "image", "label": "Desktop image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },

    { "type": "header", "content": "Image overlay" },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Overlay style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%",
      "default": 0,
      "info": "Only applies when overlay style is Dark or Light."
    },

    { "type": "header", "content": "Banner height (same as Slideshow section)" },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 300, "max": 1000, "step": 10, "unit": "px",
      "default": 800,
      "label": "Desktop height"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200, "max": 800, "step": 10, "unit": "px",
      "default": 480,
      "label": "Mobile height"
    },

    { "type": "header", "content": "Heading (centered)" },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "We use active ingredients that your skin actually <em><strong>needs</strong></em>."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#F4E9C8" },
    {
      "type": "text",
      "id": "heading_font_family",
      "label": "Heading font-family (CSS)",
      "info": "Optional. Leave empty to inherit theme heading font. Example: 'Inter', sans-serif"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "300 — Light" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "500", "label": "500 — Medium" },
        { "value": "600", "label": "600 — Semibold" },
        { "value": "700", "label": "700 — Bold" }
      ]
    },
    {
      "type": "select",
      "id": "heading_case",
      "label": "Heading case",
      "default": "sentence",
      "options": [
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "lowercase", "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize Each Word" },
        { "value": "sentence",   "label": "Sentence case" },
        { "value": "as_typed",   "label": "As typed" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading font size — Desktop",
      "min": 16, "max": 120, "step": 2, "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_line_height_desktop",
      "label": "Heading line height — Desktop",
      "min": 16, "max": 160, "step": 2, "unit": "px",
      "default": 54
    },
    {
      "type": "range",
      "id": "heading_letter_spacing_desktop",
      "label": "Heading letter spacing — Desktop",
      "min": -5, "max": 10, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_word_spacing_desktop",
      "label": "Heading word spacing — Desktop",
      "min": -5, "max": 20, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_max_width_desktop",
      "label": "Heading max width — Desktop",
      "min": 200, "max": 1400, "step": 20, "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "heading_padding_x_desktop",
      "label": "Heading padding L/R — Desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_padding_y_desktop",
      "label": "Heading padding T/B — Desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_offset_y_desktop",
      "label": "Heading vertical offset — Desktop",
      "min": -200, "max": 200, "step": 4, "unit": "px",
      "default": 0,
      "info": "Negative pulls heading up; useful to add gap above description."
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size — Mobile",
      "min": 14, "max": 72, "step": 1, "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "heading_line_height_mobile",
      "label": "Heading line height — Mobile",
      "min": 14, "max": 100, "step": 1, "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_letter_spacing_mobile",
      "label": "Heading letter spacing — Mobile",
      "min": -5, "max": 10, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_word_spacing_mobile",
      "label": "Heading word spacing — Mobile",
      "min": -5, "max": 20, "step": 1, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_max_width_mobile",
      "label": "Heading max width — Mobile",
      "min": 200, "max": 800, "step": 10, "unit": "px",
      "default": 340
    },
    {
      "type": "range",
      "id": "heading_padding_x_mobile",
      "label": "Heading padding L/R — Mobile",
      "min": 0, "max": 60, "step": 2, "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_padding_y_mobile",
