<style>
/* Inlined hero overlay styles - uses Aeonik when available. */

@font-face {
  font-family: 'Inter';
  src: local('Inter'), local('Aeonik-Regular');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

.hero-overlay{
  position: relative;
  overflow: hidden;
}

.hero-image{
  display: block;
  width: 100%;
  height: 480px;
  object-fit: cover;
}

.hero-content{
  position: absolute;
  left: 4%;
  top: 50%;
  transform: translateY(-50%);
  color: #000;
  max-width: 48%;
  padding: 0 1rem;
  pointer-events: none;
}

.hero-heading{
  margin: 0 0 8px 0;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  font-weight: 400;
  font-style: normal;
  font-size: 34px;
  line-height: 38px;
  -webkit-font-smoothing: antialiased;
  letter-spacing: 0%;
  vertical-align: middle;
  pointer-events: auto;
  background: transparent;
}

.hero-description{
  margin: 0;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  font-weight: 400;
  font-style: normal;
  font-size: 18px;
  line-height: 24px;
  letter-spacing: 0%;
  vertical-align: middle;
  color: #000;
  pointer-events: auto;
}

.hero-overlay .hero-heading{
  transform-origin: left center;
}

@media (max-width: 900px){
  .hero-image{ height: 360px; }
  .hero-content{ max-width: 70%; left: 6%; }
  .hero-heading{ font-size: 28px; line-height: 32px; }
  .hero-description{ font-size: 16px; line-height: 22px; }
}

@media (max-width: 480px){
  .hero-image{ height: 260px; }
  .hero-content{ position: absolute; left: 6%; right:6%; max-width: none; top: 50%; transform: translateY(-50%); }
  .hero-heading{ font-size: 22px; line-height: 26px; }
  .hero-description{ font-size: 14px; line-height: 20px; }
}
</style>

<section class="hero-overlay" role="region" aria-label="Hero with overlay">
  {% if section.settings.image != blank %}
    <img class="hero-image" src="{{ section.settings.image | img_url: '2048x' }}" alt="{{ section.settings.image_alt | escape }}" />
  {% endif %}

  <div class="hero-content" style="text-align: {{ section.settings.align }};">
    <h2 class="hero-heading">{{ section.settings.heading }}</h2>
    {% if section.settings.description != blank %}
      <p class="hero-description">{{ section.settings.description }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero overlay",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your heading here"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Your description here"
    },
    {
      "type": "select",
      "id": "align",
      "label": "Content alignment",
      "options": [
        {"value":"left","label":"Left"},
        {"value":"center","label":"Center"},
        {"value":"right","label":"Right"}
      ],
      "default": "left"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Hero overlay",
      "category": "Image"
    }
  ]
}
{% endschema %}